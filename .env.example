# ---- OpenRouter (LLM) ----
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Per-role models (cheap = Haiku, complex = Sonnet)
MODEL_CHEAP=anthropic/claude-3.5-haiku
MODEL_SMART=anthropic/claude-sonnet-4.5
# Optional attribution headers for OpenRouter
OPENROUTER_APP_TITLE=nl2databricks
OPENROUTER_SITE_URL=http://localhost:8501

# ---- Databricks (real SQL Warehouse) ----
DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxx
DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxx
DATABRICKS_CATALOG=main

# ---- App behaviour ----
MAX_REPAIR_ATTEMPTS=3
READ_ONLY=true
RESULT_ROW_LIMIT=100
SCHEMA_TOP_TABLES=8
API_BASE_URL=http://localhost:8000
